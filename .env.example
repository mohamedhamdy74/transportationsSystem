# Appwrite (required for production)
VITE_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_PROJECT_NAME=Transportations System
VITE_APPWRITE_DATABASE_ID=your_database_id
VITE_APPWRITE_COLLECTION_INSPECTIONS=inspections
VITE_APPWRITE_COLLECTION_GPS_VEHICLES=gps_vehicles
VITE_APPWRITE_COLLECTION_DAILY_PLANS=daily_plans
VITE_APPWRITE_COLLECTION_REQUESTS=requests
VITE_APPWRITE_COLLECTION_ACCOUNTS=accounts
VITE_APPWRITE_COLLECTION_USER_PROFILES=user_profiles

# Auth teams (create in Appwrite Console or via scripts/setup-auth.mjs)
VITE_APPWRITE_TEAM_ADMINS=admins
VITE_APPWRITE_TEAM_INSPECTORS=inspectors
VITE_AUTH_EMAIL_DOMAIN=transport.local

# Server-only (Vercel / setup script — NEVER prefix with VITE_)
APPWRITE_API_KEY=standard_252587c36c976dbc7186931b663aa3cb18cd3076683f70a69cdb2e4f1f4ea0c59bd10bcbcd55fcbd68e17d5dcf434bfce5a0bb169f7bade19af8c022a9b89c201b75b0458136f427b3c5e55bf7fb3479f78e6b16d87471f2c41ccd4ad72f3a64a7b4fc82269cb57d63ab464aa3454d54f72a7dbaabffda201f75f130f654cc75

# UI / security (production: keep demo off, passwords hidden)
VITE_ENABLE_DEMO_LOGIN=false
VITE_SHOW_PASSWORDS_IN_UI=false
VITE_SESSION_MAX_HOURS=8
VITE_PAGINATION_PAGE_SIZE=50
